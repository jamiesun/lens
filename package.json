{
  "name": "lens",
  "description": "A local-first frontend agent runtime for the browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:test": "node scripts/dev-test.mjs",
    "dev:fixture": "node tests/fixtures/server.mjs",
    "icons": "node scripts/render-icons.mjs",
    "build": "wxt build",
    "build:test": "wxt build --mode test",
    "build:e2e": "wxt build --mode e2e",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build:e2e && playwright test",
    "check": "npm run compile && npm run test && npm run build",
    "package": "npm run zip",
    "zip": "wxt zip",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "happy-dom": "^20.10.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.6",
    "uuid@<11.1.1": "^11.1.1"
  }
}
